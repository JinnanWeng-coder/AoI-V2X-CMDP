__pycache__/
*.pyc
.idea/

# nested un-edited duplicate of the project (kept on disk, not tracked)
AoI-V2X-backup-main/

data/

# model/**/*.mat are now tracked via Git LFS (see .gitattributes); only .png stay ignored
**/model/**/*.png

# NARROW exception: the curated raw-.mat archive for off-machine reproducibility
# (results_remote/raw/all_runs_mat.tar.gz + MANIFEST). Does NOT un-ignore the model/
# tree, checkpoints, TB events, or logs — scoped only to results_remote/raw/.
!results_remote/raw/
!results_remote/raw/**
# ...but still keep python caches out of the tracked raw dir
results_remote/raw/__pycache__/
results_remote/raw/*.pyc

**/Classes/tmp/ddpg/*
!**/Classes/tmp/ddpg/*.txt

# per-run checkpoint subdirs (RQ1_CKPT_SUBDIR), TensorBoard events, run logs
# — all runtime artifacts, regenerated on each machine; keep them out of git
**/Classes/tmp/ddpg_*/
**/runs/**/events.out.*
**/logs/
results_local/__pycache__/
results_remote/__pycache__/

# local virtual env (inherits shared conda torch+CUDA via --system-site-packages)
.venv/